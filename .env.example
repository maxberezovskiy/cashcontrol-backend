PROJECT_NAME=CashControl
VERSION=0.1.0

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cashcontrol

SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Общий секрет между backend и Telegram-ботом (сервисные endpoint-ы /telegram/link и /telegram/token)
BOT_API_SECRET=change-me-to-a-random-bot-secret
TELEGRAM_LINK_CODE_TTL_MINUTES=10

# --- Админ-фича: почта и сброс пароля ---
# SMTP-аккаунт (хост/порт/логин/пароль/отправитель) НЕ задаётся здесь — его вводит
# суперпользователь через web-UI (/admin/settings/smtp), пароль шифруется и хранится в БД.

# Ключ шифрования SMTP-пароля at-rest (Fernet). В dev можно не задавать — выведется из SECRET_KEY.
# В ПРОДЕ ОБЯЗАТЕЛЕН и постоянен: при его потере сохранённый SMTP-пароль не расшифровать.
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENC_KEY=
# Базовый URL фронтенда — из него собирается ссылка сброса пароля в письме.
FRONTEND_BASE_URL=http://localhost:5173
# Время жизни токена сброса пароля (минут).
PASSWORD_RESET_TTL_MINUTES=60
# Этот email при каждом старте повышается до admin (promote-only). Должен быть уже зарегистрирован.
FIRST_SUPERUSER_EMAIL=berezovskiy.max@mail.ru
